# Root env for docker compose (copy to .env on server).
# Leave PUBLIC_API_URL empty: frontend uses same-origin /api/v1 (Nginx → FastAPI).
PUBLIC_API_URL=
POSTGRES_PASSWORD=postgres
OPENAI_API_KEY=
APOLLO_API_KEY=
RESEND_API_KEY=

# Auth (NextAuth v5)
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=https://tokenply.world
# Same origin you use in the browser (if you standardize on www, set both to https://www.tokenply.world).
AUTH_URL=https://tokenply.world
# Comma-separated emails that can access the platform admin surface.
TITAN_ADMIN_EMAILS=

# Google OAuth (optional — create at console.cloud.google.com)
# Authorized redirect URI: https://tokenply.world/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LLM providers (LiteLLM). Fill only the keys you use.
# Default stack targets DeepSeek V4 (see https://api-docs.deepseek.com/quick_start/pricing ).
# If you only configure OpenAI (or others), set e.g. LITELLM_DEFAULT_MODEL=gpt-4o-mini
LITELLM_DEFAULT_MODEL=deepseek/deepseek-v4-pro
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
# Optional. Official API: https://api.deepseek.com (LiteLLM also supports beta URL).
DEEPSEEK_API_BASE=https://api.deepseek.com
MISTRAL_API_KEY=
COHERE_API_KEY=
TOGETHERAI_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
PERPLEXITYAI_API_KEY=
# Research (M07b) — Exa preferred when set
EXA_API_KEY=

# Computer Use / Agent-S (M03) — isolated runner service
COMPUTER_USE_RUNNER_URL=http://computer-use-runner:8090
COMPUTER_USE_RUNNER_TOKEN=dev-runner-token
# stub = simulated steps (default); live = gui-agents + grounding
AGENT_S_MODE=stub
COMPUTER_USE_GROUND_URL=
COMPUTER_USE_GROUND_MODEL=ui-tars-1.5-7b
# Alibaba Cloud DashScope (Qwen)
DASHSCOPE_API_KEY=
MOONSHOT_API_KEY=
ZHIPUAI_API_KEY=
BAICHUAN_API_KEY=
SILICONFLOW_API_KEY=
# MiniMax (https://www.minimax.io)
MINIMAX_API_KEY=
MINIMAX_API_BASE=
# ByteDance Volcengine Ark / 豆包 (VOLCENGINE_API_KEY or ARK_API_KEY)
VOLCENGINE_API_KEY=
ARK_API_KEY=

# Azure OpenAI / AWS Bedrock
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=
